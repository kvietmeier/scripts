### .bash_environment
# This file is sourced by .bashrc and .profile 
# Put environment variables here that you want set in all your bash sessions

###--- VAST environment variables
export VMS_USER=
export VMS_PASSWORD=
export VMS_ADDRESS=vms


###--- AWS environment variables
#export AWS_ACCESS_KEY_ID=your-access-key-id
#export AWS_SECRET_ACCESS_KEY=your-secret-access-key
#export AWS_DEFAULT_REGION=your-default-region

# Set the default AWS profile
export AWS_PROFILE=AWS-POC-VOC-Cluster

###--- GCP environment variables
export GOOGLE_APPLICATION_CREDENTIALS=
export GCP_DEFAULT_PROJECT=


###--- Azure environment variables
### Assumes environment variables are set in .bash_environment or manually:
export AZURE_CLIENT_ID=
export AZURE_CLIENT_SECRET=
export AZURE_TENANT_ID=
export AZURE_SUBSCRIPTION_ID=
export AZURE_SUBSCRIPTION_NAME=
export AZURE_TENANT_DOMAIN=
export AZURE_RESOURCE_GROUP=
